			<?php

	
			$today = strtotime('today');

			// Пагинация
			$paged = (get_query_var('paged') ? get_query_var('paged') : 1);
			$posts_per_page = ($paged == 1 ? 7 : 4);

			// Запрос для получения постов с фильтром по дате game_date >= сегодня
			$query = new WP_Query(array(
				'post_type' => 'games',
				'posts_per_page' => $posts_per_page,
				'paged' => $paged,
				'orderby' => [
					'meta_value_num' => 'ASC',
					'post_date' => 'DESC',
				],
				'meta_query' => array(
					array(
						'key' => 'game_date',
						'value' => $today,
						'compare' => '>=', // Только сегодня и будущие даты
						'type' => 'NUMERIC',
					),
				),
				'tax_query' => array(
					array(
						'taxonomy' => 'city',
						'field' => 'term_id',
						'terms' => $_COOKIE['selected_city'],
					),
				),
			));

			wp_localize_script('ajax-posts', $ajaxVariable, array(
				'ajaxurl' => admin_url('admin-ajax.php'),
				'query_vars' => json_encode($query->query_vars),
				'current_page' => max(1, get_query_var('paged')),
				'max_pages' => $query->max_num_pages,
			));
			?>

			<div class="player-items ajax-posts__items">
				<div class="player-item" data-modal=".player-modal">

